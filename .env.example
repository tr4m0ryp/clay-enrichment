# Gemini AI API (paid tier)
GEMINI_API_KEY="your-gemini-api-key"

# SearXNG (self-hosted meta-search engine, replaces Google CSE)
# Start with: docker run -d -p 8888:8080 --name searxng searxng/searxng
SEARXNG_URL="http://localhost:8888"

# Google Custom Search API (deprecated -- closed to new customers)
# GOOGLE_API_KEY="your-google-api-key"
# GOOGLE_CSE_ID="your-custom-search-engine-id"

# Notion API
NOTION_API_KEY="your-notion-integration-token"
NOTION_HUB_PAGE_ID="your-notion-hub-page-id"
NOTION_CAMPAIGNS_DB_ID=""
NOTION_COMPANIES_DB_ID=""
NOTION_CONTACTS_DB_ID=""
NOTION_EMAILS_DB_ID=""
NOTION_CONTACT_CAMPAIGNS_DB_ID=""
NOTION_LEADS_PAGE_ID=""

# Email Sending (SMTP)
SMTP_HOST=""
SMTP_PORT=587
# SENDER_1_EMAIL="outreach1@yourdomain.com"
# SENDER_1_PASSWORD="app-password"
# SENDER_2_EMAIL="outreach2@yourdomain.com"
# SENDER_2_PASSWORD="app-password"

# Email Sending Limits
EMAIL_DAILY_LIMIT_PER_SENDER=10
EMAIL_MIN_DELAY_SECONDS=180
EMAIL_MAX_DELAY_SECONDS=480

# Enrichment Settings
ENRICHMENT_STALE_DAYS=90

# Model Configuration
MODEL_DISCOVERY="gemini-2.5-flash-lite"
MODEL_ENRICHMENT="gemini-2.5-flash-lite"
MODEL_SCORING="gemini-2.5-flash-lite"
MODEL_CONTACT_EXTRACTION="gemini-2.5-flash-lite"
MODEL_EMAIL_GENERATION="gemini-2.5-flash"

# --- Supabase ---
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DB_URL="postgresql://postgres.<ref>:<password>@db.<ref>.supabase.co:5432/postgres"

# --- GitHub PAT pool (used by scripts/init_github_tokens.py) ---
GITHUB_PAT_1=""
GITHUB_PAT_2=""

# --- Pool tuning ---
KEY_POOL_CIRCUIT_MAX_COOLDOWN_SEC=14400
CLAY_SCRAPE_LIMIT=200
CLAY_VALIDATE_BATCH=50

# --- Auth provisioning (only used by scripts/init_supabase_auth.py) ---
MOUSSA_EMAIL="moussa@avelero.com"
MOUSSA_PASSWORD=""

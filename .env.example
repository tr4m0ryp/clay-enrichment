# AI Model (Gemini)
GOOGLE_API_KEY=your-gemini-api-key

# Web Search (Serper API -- serper.dev)
SERPER_API_KEY=your-serper-api-key

# LinkedIn Scraping (RapidAPI)
RAPIDAPI_KEY=your-rapidapi-key

# Notion CRM
NOTION_API_KEY=secret_xxx
NOTION_PARENT_PAGE_ID=your-parent-page-id-for-database-setup
NOTION_COMPANIES_DB_ID=your-companies-database-id
NOTION_EMAILS_DB_ID=your-emails-database-id

# Email Sending (SMTP)
EMAIL_SENDER_ADDRESSES=outreach1@avelero.com,outreach2@avelero.com
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_PASSWORD=your-smtp-password
EMAIL_DELAY_SECONDS=15
EMAIL_MAX_PER_SENDER_PER_HOUR=20
EMAIL_POLL_INTERVAL_SECONDS=300

# Pipeline Configuration
DISCOVERY_INTERVAL_SECONDS=60
DPP_FIT_THRESHOLD=6

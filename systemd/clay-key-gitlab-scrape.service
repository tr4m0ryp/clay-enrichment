[Unit]
Description=Clay key scraper -- GitLab.com (independent of GitHub scrape)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=clay
WorkingDirectory=/opt/clay-enrichment
EnvironmentFile=/opt/clay-enrichment/.env
ExecStart=/opt/clay-enrichment/.venv/bin/python -m src.api_keys.cron.gitlab_scrape
StandardOutput=journal
StandardError=journal

# Supabase project. Required for the dashboard, the auth gate, and the
# admin/SSR clients in src/lib/supabase/.

# Project URL, e.g. https://osrvoybsqvwugzkujijp.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon key. Used by the browser client and the middleware. Safe to expose.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. Bypasses RLS. Server-only -- never imported from a
# "use client" boundary.
SUPABASE_SERVICE_ROLE_KEY=
